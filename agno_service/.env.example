AGNO_HOST=127.0.0.1
AGNO_PORT=8000
# Optional zero-key local path. For deployment environments such as Cloudflare,
# switch to the remote OpenAI-compatible example below instead of Ollama.
AGNO_MODEL_PROVIDER=ollama
AGNO_OLLAMA_HOST=http://127.0.0.1:11434

# OpenAI-compatible endpoint. Recommended for remote deployment.
AGNO_OPENAI_API_KEY=
AGNO_OPENAI_BASE_URL=

# Remote provider example:
# AGNO_MODEL_PROVIDER=openai
# AGNO_OPENAI_API_KEY=your_provider_key
# AGNO_OPENAI_BASE_URL=https://your-provider.example/v1
# AGNO_DEFAULT_MODEL=your-provider-model
# AGNO_MODEL_ALIASES={"glm-4.7-flash":"your-provider-model","doubao-seed-1.6-flash":"your-provider-model"}

# Free local default. If your machine can handle it, you can upgrade to qwen2.5:7b.
AGNO_DEFAULT_MODEL=qwen2.5:3b
AGNO_MODEL_ALIASES={"glm-4.7-flash":"qwen2.5:3b","doubao-seed-1.6-flash":"qwen2.5:3b"}

AGNO_REQUEST_TIMEOUT=120
AGNO_MAX_RETRIES=2
AGNO_STREAM_CHUNK_SIZE=48
AGNO_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional Vite override when you do not want to use the default local target.
VITE_AI_PROXY_TARGET=http://127.0.0.1:8000