# Vercel frontend env
VITE_API_BASE_URL=/api

# Optional: keep empty or remove if you still want to use the official image search service
# VITE_IMAGE_SEARCH_BASE_URL=https://your-image-search-service.example.com

# Agno backend env
AGNO_MODEL_PROVIDER=openai
AGNO_OPENAI_API_KEY=REPLACE_WITH_YOUR_BIGMODEL_KEY
AGNO_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
AGNO_DEFAULT_MODEL=glm-4.7-flash
AGNO_MODEL_ALIASES={"glm-4.7-flash":"glm-4.7-flash","doubao-seed-1.6-flash":"glm-4.7-flash","gemini-2.5-flash":"glm-4.7-flash","gemini-2.5-flash-lite":"glm-4.7-flash"}
AGNO_REQUEST_TIMEOUT=120
AGNO_MAX_RETRIES=2
AGNO_STREAM_CHUNK_SIZE=48

# Optional: add your production domain after you have one
# AGNO_CORS_ORIGINS=https://your-domain.example.com